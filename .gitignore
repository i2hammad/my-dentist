# ─── Dependencies ────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Environment / secrets — NEVER commit ────────────────────
.env
.env.local
.env*.local
.env.production
**/.env
!**/.env.example

# ─── Build artifacts (zips / APKs) ───────────────────────────
mydentist-*.zip
*.apk

# ─── Expo / React Native ─────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# Generated native folders
**/ios/
**/android/

# Signing / native secrets
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*

# ─── Backend uploads (user-generated) ────────────────────────
backend/uploads/
backend/backups/

# ─── Generated Prisma client + engine binaries (rebuilt via `prisma generate`) ─
backend/generated/

# ─── DB backups / dumps (contain real user data) ─────────────
db-backup/
**/db-backup/
*.bson

# ─── Logs / debug ────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ─── OS / editor ─────────────────────────────────────────────
.DS_Store
*.tsbuildinfo
