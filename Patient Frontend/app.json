{
  "expo": {
    "name": "My Dentist",
    "slug": "patient-app",
    "scheme": "mydentist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mydentist.patientapp"
    },
    "android": {
      "package": "com.mydentist.patientapp",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/app-logo.png",
        "monochromeImage": "./assets/app-logo.png"
      }
    },
    "web": {
      "favicon": "./assets/app-logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow My Dentist to use your location to set your clinic's precise coordinates."
        }
      ]
    ]
  }
}
