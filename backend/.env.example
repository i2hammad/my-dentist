# Copy this file to .env and fill in your own values. Do NOT commit the real .env.

PORT=5000

# MongoDB connection string (Atlas or local). Keep credentials out of git.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Med_App?retryWrites=true&w=majority
DB_NAME=Med_App

# JWT secrets — use long random strings in production
JWT_SECRET=replace_with_a_strong_random_string
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_string
JWT_REFRESH_EXPIRE=30d

NODE_ENV=development

# Cloudinary — image uploads (avatars + gallery). Get from cloudinary.com.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (forgot-password). For Gmail use an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=mydentist840@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=My Dentist PK <mydentist840@gmail.com>
