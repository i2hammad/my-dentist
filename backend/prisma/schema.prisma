// Prisma schema — PostgreSQL migration from MongoDB/Mongoose.
//
// Conventions:
//  - IDs are string cuid() (opaque strings, so the frontend's string-id logic
//    keeps working). API responses expose them as `_id` via a serializer.
//  - Nested Mongo subdocuments / arrays-of-objects → Json (JSONB) columns.
//  - Arrays of scalars → Postgres String[].
//  - Enum-ish fields kept as String (validated in app code, matches Mongoose).
//  - Scalar FK fields keep their Mongo names (patientId/doctorId/userId/…) so
//    the serializer can nest the related object under that name (populate shape).
//  - Loose/polymorphic refs (Notification.relatedId, AuditLog.*, referredBy,
//    Review.helpfulBy) are plain String / String[] columns, not relations.

generator client {
  provider = "prisma-client-js"
  // Generate the client INTO the repo (not node_modules) so it can be built
  // locally and shipped in the deploy zip — the shared host can't run
  // `prisma generate` (WASM schema builder gets OOM-killed under CloudLinux LVE).
  output   = "../generated/prisma"
  // Bundle query-engine binaries for the deploy host plus the local dev machine
  // so the pre-generated client runs on the server as-is. The LiteSpeed app
  // runtime detects OpenSSL 1.0.x (even though the SSH shell reports 1.1.x), so
  // 1.0.x is required; 1.1.x/3.0.x kept as safety nets.
  binaryTargets = ["native", "debian-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  role           String
  isAgreed       Boolean  @default(false)
  socialProvider String?
  socialId       String?
  refreshToken   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  adminProfile     AdminProfile?
  doctorProfile    DoctorProfile?
  patientProfile   PatientProfile?
  paymentMethods   PaymentMethod[]
  notifications    Notification[]
  sentMessages     ChatMessage[]   @relation("SentMessages")
  receivedMessages ChatMessage[]   @relation("ReceivedMessages")
  favorites        Favorite[]      @relation("UserFavorites")
}

model AdminProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  adminRole    String    @default("admin")
  permissions  String[]  @default(["dashboard", "admins", "dentists", "patients", "treatments", "gallery", "reviews", "appointments", "bills", "rewards"])
  status       String    @default("active")
  profileImage String    @default("")
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AppSettings {
  id                             String   @id @default(cuid())
  key                            String   @unique @default("global")
  rewardPointsPerAppointment     Int      @default(50)
  rewardPointValuePkr            Int      @default(1)
  defaultConsultationFee         Int      @default(1500)
  payments                       Json?
  enabledPaymentMethods          String[] @default(["visa", "mastercard", "easypaisa", "jazzcash", "bank"])
  supportEmail                   String   @default("")
  maintenanceMode                Boolean  @default(false)
  popularPointsThreshold         Int      @default(20000)
  popularPaidAmountPkr           Int      @default(100000)
  commissionRate                 Int      @default(10)
  commissionBlockThreshold       Int      @default(50000) // dues (PKR) at which a doctor is auto-blocked
  campaignRotationInterval       Int      @default(10)
  doctorCampaignRotationInterval Int      @default(10)
  facilityCategories             Json?
  clinicTierThresholds           Json?
  smtp                           Json? // { host, port, user, pass, from, insecure } — email/forgot-password config
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model Appointment {
  id                String         @id @default(cuid())
  patientId         String
  patient           PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId          String
  doctor            DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  treatmentType     String
  description       String         @default("")
  date              DateTime
  time              String
  duration          Int            @default(30)
  status            String         @default("pending")
  consultationType  String         @default("offline")
  visitSummary      String         @default("")
  rescheduleRequest Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  bills Bill[]

  @@index([patientId, date])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actorName   String   @default("")
  action      String
  entity      String   @default("")
  entityId    String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

model Bill {
  id                  String         @id @default(cuid())
  appointmentId       String?
  appointment         Appointment?   @relation(fields: [appointmentId], references: [id])
  patientId           String
  patient             PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId            String
  doctor              DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  invoiceNumber       String         @unique
  treatmentName       String
  treatments          Json?
  amount              Float
  discountFromRewards Float          @default(0)
  finalAmount         Float          @default(0)
  paidAmount          Float          @default(0)
  commissionAccrued   Float          @default(0)
  status              String         @default("unpaid")
  paymentMethodId     String?
  paymentMethod       PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentMethodLabel  String         @default("")
  paymentType         String?
  dueDate             DateTime?
  paidAt              DateTime?
  refundReason        String         @default("")
  refundedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  rewards Reward[]
}

model Campaign {
  id             String   @id @default(cuid())
  title          String
  bannerText     String   @default("")
  body           String   @default("")
  medicineName   String   @default("")
  company        String   @default("")
  bannerImage    String   @default("")
  detailImage    String   @default("")
  ctaLabel       String   @default("Learn More")
  ctaLink        String   @default("")
  targetAudience String   @default("doctor")
  cities         String[] @default([])
  startAt        DateTime
  endAt          DateTime
  isActive       Boolean  @default(true)
  views          Int      @default(0)
  clicks         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ChatMessage {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  message     String
  isRead      Boolean   @default(false)
  isDelivered Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([senderId, receiverId, createdAt])
}

model CommissionLog {
  id           String        @id @default(cuid())
  doctorId     String
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorName   String        @default("")
  type         String
  amount       Float         @default(0)
  balanceAfter Float         @default(0)
  note         String        @default("")
  actorName    String        @default("")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([doctorId])
  @@index([createdAt])
}

model DoctorProfile {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String
  photo             String          @default("")
  specialization    String
  pmdcNumber        String          @default("")
  gender            String          @default("")
  clinicContact     String          @default("")
  city              String          @default("")
  phone             String          @default("")
  licenseCert       String          @default("")
  idFront           String          @default("")
  idBack            String          @default("")
  qualification     String          @default("")
  consultationFee   Float           @default(1500)
  experience        Float           @default(0)
  clinicName        String          @default("")
  clinicTier        String          @default("standard")
  facilityScore     Float           @default(0)
  payoutAccount     Json?
  pmdcVerified      Boolean         @default(false)
  languages         String[]        @default(["English", "Urdu"])
  clinicTiming      Json?
  onlineStatus      String          @default("offline")
  about             String          @default("")
  address           String          @default("")
  coordinates       String          @default("")
  lat               Float? // geo: extracted from location for haversine queries
  lng               Float?
  services          String[]        @default([])
  rewardPoints      Float           @default(0)
  pointsAdjustments Json?
  referralCode      String?         @unique
  referredBy        String? // self-ref (doctor→doctor); kept loose to avoid FK cycles
  referrer          DoctorProfile?  @relation("DoctorReferrals", fields: [referredBy], references: [id])
  referredDoctors   DoctorProfile[] @relation("DoctorReferrals")
  referralRewarded  Boolean         @default(false)
  isPopular         Boolean         @default(false)
  approvalStatus    String          @default("pending")
  isBlocked         Boolean         @default(false)
  blockReason       String          @default("")
  commissionDue     Float           @default(0)
  commissionPaid    Float           @default(0)
  popularType       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  appointments   Appointment[]
  bills          Bill[]
  reviews        Review[]
  treatments     Treatment[]
  galleries      Gallery[]
  commissionLogs CommissionLog[]
  favorites      Favorite[]
  rewards        Reward[]

  @@index([lat, lng])
}

model Favorite {
  id        String        @id @default(cuid())
  patientId String // refs User (kept as in Mongo)
  patient   User          @relation("UserFavorites", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([patientId, doctorId])
}

model Gallery {
  id          String        @id @default(cuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  category    String
  imageUrl    String
  title       String        @default("")
  description String        @default("")
  beforeImage String?
  afterImage  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("system")
  isRead    Boolean  @default(false)
  relatedId String? // polymorphic, no relation
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead, createdAt])
}

model PatientProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  mobileNumber     String    @default("")
  dateOfBirth      DateTime?
  gender           String?
  city             String    @default("")
  lat              Float?
  lng              Float?
  profileImage     String    @default("")
  age              Int?
  address          String    @default("")
  coordinates      String    @default("")
  familyMembers    Json?
  referralCode     String?   @unique
  referredBy       String? // polymorphic (refPath referredByModel) — loose string
  referredByModel  String    @default("PatientProfile")
  referralRewarded Boolean   @default(false)
  isBlocked        Boolean   @default(false)
  blockReason      String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointments Appointment[]
  bills        Bill[]
  reviews      Review[]
  rewards      Reward[]
}

model PaymentMethod {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String
  lastFourDigits String?
  cardHolderName String?
  expiryDate     String?
  accountNumber  String?
  bankName       String?
  iban           String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bills Bill[]
}

model Review {
  id                String         @id @default(cuid())
  patientId         String
  patient           PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId          String
  doctor            DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  rating            Int
  comment           String         @default("")
  isVerifiedPatient Boolean        @default(false)
  hidden            Boolean        @default(false)
  helpfulCount      Int            @default(0)
  helpfulBy         String[]       @default([]) // user ids
  doctorReply       Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([doctorId, createdAt])
}

model Reward {
  id           String         @id @default(cuid())
  patientId    String
  patient      PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId     String?
  doctor       DoctorProfile? @relation(fields: [doctorId], references: [id])
  type         String
  points       Float
  description  String         @default("")
  referralCode String?
  isRedeemed   Boolean        @default(false)
  billId       String?
  bill         Bill?          @relation(fields: [billId], references: [id])
  appliedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ScheduledBroadcast {
  id        String    @id @default(cuid())
  title     String
  message   String
  audience  String    @default("all")
  city      String    @default("")
  sendAt    DateTime
  status    String    @default("scheduled")
  sentCount Int       @default(0)
  sentAt    DateTime?
  error     String    @default("")
  createdBy String? // loose ref to User
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, sendAt])
}

model Treatment {
  id        String        @id @default(cuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  name      String
  priceMin  Float         @default(0)
  priceMax  Float         @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
